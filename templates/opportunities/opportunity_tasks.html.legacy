{# LLM INFO: Ruta de origen de la plantilla. Django elimina este bloque al renderizar. #}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Opportunity Tasks · OptiGrid CRM</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; background: #f6f7f9; color: #1f2937; }
    .page { max-width: 1200px; margin: 0 auto; }
    .header { margin-bottom: 18px; }
    .header h1 { margin: 0 0 6px 0; }
    .header p { margin: 0; color: #6b7280; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; gap: 12px; flex-wrap: wrap; }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .link-btn { display: inline-block; padding: 8px 12px; border-radius: 8px; background: #111827; color: #fff; text-decoration: none; font-size: 13px; font-weight: 700; }
    .link-btn.secondary { background: #374151; }
    .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; overflow: hidden; margin-bottom: 18px; }
    .section { padding: 16px; }
    .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
    .stat { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px; }
    .stat .label { font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: .04em; }
    .stat .value { font-size: 22px; font-weight: 800; margin-top: 6px; }
    .subvalue { margin-top: 6px; font-size: 12px; color: #6b7280; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 14px 12px; text-align: left; vertical-align: top; border-bottom: 1px solid #f0f2f4; font-size: 14px; }
    th { background: #f9fafb; color: #374151; font-weight: 700; }
    .badges { display: flex; flex-wrap: wrap; gap: 6px; }
    .badge { display: inline-block; padding: 4px 8px; border-radius: 999px; font-size: 12px; font-weight: 700; line-height: 1; }
    .badge-auto { background: #cffafe; color: #155e75; }
    .badge-manual { background: #e5e7eb; color: #374151; }
    .badge-status { background: #ede9fe; color: #5b21b6; }
    .badge-priority { background: #dcfce7; color: #166534; }
    .badge-risk { background: #fce7f3; color: #9d174d; }
    .badge-high { background: #fee2e2; color: #991b1b; }
    .badge-medium { background: #fef3c7; color: #92400e; }
    .badge-monitor { background: #dbeafe; color: #1d4ed8; }
    .badge-low { background: #e5e7eb; color: #374151; }
    .muted { color: #6b7280; }
    .empty { padding: 24px; color: #6b7280; text-align: center; }
    .task-title { font-weight: 700; }
    .task-meta { margin-top: 6px; font-size: 12px; color: #6b7280; }
    .small-note { margin-top: 4px; font-size: 12px; color: #6b7280; }
    @media (max-width: 960px) {
      .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 640px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      <div class="header">
        <h1>{{ opportunity.title }}</h1>
        <p>
          {{ opportunity.company_name|default:"—" }}
          · stage {{ opportunity.stage }}
          · score {{ priority_row.relevance_score }}
        </p>
      </div>
      <div class="actions">
        <a class="link-btn secondary" href="{% url 'prioritized_opportunities' %}">Back to prioritized view</a>
      </div>
    </div>

    <div class="card section">
      <div class="grid">
        <div class="stat">
          <div class="label">Priority</div>
          <div class="value">
            <span class="badge badge-{{ priority_row.priority_bucket }}">
              {{ priority_row.priority_label|default:priority_row.priority_bucket }}
            </span>
          </div>
        </div>

        <div class="stat">
          <div class="label">Open tasks</div>
          <div class="value">{{ open_tasks_count }}</div>
          <div class="subvalue">Currently open or in progress</div>
        </div>

        <div class="stat">
          <div class="label">Auto tasks</div>
          <div class="value">{{ auto_tasks_count }}</div>
          <div class="subvalue">Generated by opportunity intelligence</div>
        </div>

        <div class="stat">
          <div class="label">Execution</div>
          <div class="value">
            {% if priority_row.execution_status == "blocked" %}
              <span class="badge badge-risk">BLOCKED</span>
            {% elif priority_row.execution_status == "auto_task_open" %}
              <span class="badge badge-auto">AUTO RUNNING</span>
            {% elif priority_row.execution_status == "task_open" %}
              <span class="badge badge-status">TASK OPEN</span>
            {% elif priority_row.execution_status == "suggested" %}
              <span class="badge badge-priority">SUGGESTED</span>
            {% elif priority_row.execution_status == "no_action" %}
              <span class="badge badge-manual">NO ACTION</span>
            {% else %}
              <span class="badge badge-status">{{ priority_row.execution_status }}</span>
            {% endif %}
          </div>
          <div class="subvalue">
            {{ priority_row.execution_status_label|default:"Operational state" }}
          </div>
        </div>
      </div>
    </div>

    <div class="card section">
      <div class="grid">
        <div class="stat">
          <div class="label">Risk flags</div>
          <div class="value" style="font-size:14px; font-weight:600;">
            {% if priority_row.risk_flag_labels %}
              <div class="badges">
                {% for flag in priority_row.risk_flag_labels %}
                  <span class="badge badge-risk">{{ flag }}</span>
                {% endfor %}
              </div>
            {% else %}
              <span class="muted">No active risk flags</span>
            {% endif %}
          </div>
        </div>

        <div class="stat">
          <div class="label">Next actions</div>
          <div class="value" style="font-size:14px; font-weight:600;">
            {% if priority_row.next_action_labels %}
              <div class="badges">
                {% for action in priority_row.next_action_labels %}
                  <span class="badge badge-priority">{{ action }}</span>
                {% endfor %}
              </div>
            {% else %}
              <span class="muted">No suggested actions</span>
            {% endif %}
          </div>
        </div>

        <div class="stat">
          <div class="label">Last analyzed</div>
          <div class="value" style="font-size:16px;">
            {% if priority_row.last_analyzed_at %}
              {{ priority_row.last_analyzed_at }}
            {% else %}
              Never analyzed
            {% endif %}
          </div>
        </div>

        <div class="stat">
          <div class="label">Last interaction</div>
          <div class="value" style="font-size:16px;">
            {% if priority_row.days_since_last_interaction is not None %}
              {{ priority_row.days_since_last_interaction }} day(s) ago
            {% else %}
              Not tracked
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      {% if tasks %}
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Task</th>
            <th>Type</th>
            <th>Status</th>
            <th>Source</th>
            <th>Source action</th>
            <th>Priority</th>
            <th>Due</th>
          </tr>
        </thead>
        <tbody>
          {% for task in tasks %}
          <tr>
            <td>#{{ task.id }}</td>

            <td>
              <div class="task-title">{{ task.title }}</div>
              {% if task.description %}
                <div class="task-meta">{{ task.description|truncatechars:140 }}</div>
              {% endif %}
              {% if task.source == "auto" %}
                <div class="small-note">Generated automatically from opportunity intelligence</div>
              {% endif %}
            </td>

            <td>
              {% if task.task_type == "follow_up" %}
                Follow up
              {% elif task.task_type == "opportunity_review" %}
                Opportunity review
              {% elif task.task_type == "review_manually" %}
                Manual review
              {% elif task.task_type == "pricing_review" %}
                Pricing review
              {% else %}
                {{ task.task_type }}
              {% endif %}
            </td>

            <td>
              <span class="badge badge-status">{{ task.status }}</span>
            </td>

            <td>
              {% if task.source == "auto" %}
                <span class="badge badge-auto">AUTO</span>
              {% else %}
                <span class="badge badge-manual">MANUAL</span>
              {% endif %}
            </td>

            <td>
              {% if task.source_action == "schedule_followup" %}
                Follow up
              {% elif task.source_action == "advance_opportunity" %}
                Review opportunity
              {% elif task.source_action == "define_next_action" %}
                Define next step
              {% elif task.source_action == "review_pricing_strategy" %}
                Review pricing
              {% elif task.source_action == "review_opportunity_stall" %}
                Review stalled
              {% else %}
                {{ task.source_action|default:"—" }}
              {% endif %}
            </td>

            <td>
              <span class="badge badge-priority">{{ task.priority }}</span>
            </td>

            <td>
              {% if task.due_at %}
                {{ task.due_at }}
              {% else %}
                —
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
        <div class="empty">No tasks found for this opportunity.</div>
      {% endif %}
    </div>
  </div>
</body>
</html>
