{# LLM INFO: Ruta de origen de la plantilla. Django elimina este bloque al renderizar. #}
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <title>Leads · OptiGrid</title>
  <style>
    body { font-family: Arial; background:#f5f6f8; margin:20px; }
    .card { background:white; padding:16px; border-radius:12px; margin-bottom:12px; }
    .row { display:flex; justify-content:space-between; }
    .scores { font-size:12px; color:#666; }
    .btn { padding:6px 10px; border-radius:8px; text-decoration:none; margin-left:6px; }
    .approve { background:#16a34a; color:white; }
    .dismiss { background:#dc2626; color:white; }
    .reopen { background:#2563eb; color:white; }
    .filters a { margin-right:10px; }
  </style>
</head>
<body>

<h1>Lead Inbox</h1>

<div class="filters">
  <a href="?status=new">New ({{ counts.new }})</a>
  <a href="?status=approved">Approved ({{ counts.approved }})</a>
  <a href="?status=dismissed">Dismissed ({{ counts.dismissed }})</a>
  <a href="?status=all">All</a>
</div>

<hr>

{% for lead in leads %}
<div class="card">
  <div class="row">
    <strong>{{ lead.company_name }}</strong>
    <div>
      {% if lead.status == "new" %}
        <a class="btn approve" href="/leads/{{ lead.id }}/approve/">Approve</a>
        <a class="btn dismiss" href="/leads/{{ lead.id }}/dismiss/">Dismiss</a>
      {% elif lead.status == "approved" %}
        <a class="btn dismiss" href="/leads/{{ lead.id }}/dismiss/">Dismiss</a>
      {% elif lead.status == "dismissed" %}
        <a class="btn reopen" href="/leads/{{ lead.id }}/reopen/">Reopen</a>
      {% endif %}
    </div>
  </div>

  <div class="scores">
    Fit: {{ lead.fit_score }} |
    Timing: {{ lead.timing_score }} |
    Novelty: {{ lead.novelty_score }}
  </div>

  <div>
    {{ lead.industry }} · {{ lead.country }} · {{ lead.employee_range }}
  </div>

  <div style="margin-top:8px;">
    {% for s in lead.signals.all %}
      <span style="font-size:12px; background:#eee; padding:4px 6px; border-radius:6px;">
        {{ s.signal_type }}: {{ s.signal_value }}
      </span>
    {% endfor %}
  </div>

</div>
{% endfor %}

</body>
</html>
