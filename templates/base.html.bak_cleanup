<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <title>{% block title %}OptiGrid CRM{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        :root {
            --app-bg: #f5f7fb;
            --app-surface: #ffffff;
            --app-text: #1f2937;
            --app-muted: #6b7280;
            --app-border: #dbe2ea;
            --app-primary: #2563eb;
            --app-sidebar: #111827;
            --app-sidebar-text: #d1d5db;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: var(--app-bg);
            color: var(--app-text);
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: var(--app-sidebar);
            color: white;
            padding: 20px;
            flex-shrink: 0;
        }

        .sidebar h2 {
            font-size: 16px;
            margin: 0 0 16px 0;
            color: #9ca3af;
            text-transform: uppercase;
        }

        .nav {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .nav a {
            color: var(--app-sidebar-text);
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 8px;
            font-weight: 600;
        }

        .nav a:hover {
            background: #1f2937;
        }

        .nav a.active {
            background: var(--app-primary);
            color: white;
        }

        .content {
            flex: 1;
            padding: 24px;
            min-width: 0;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
        }

        /* Shared UI primitives */
        .page {
            max-width: 1200px;
            margin: 0 auto;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .title-block h1 {
            margin: 0 0 6px 0;
            font-size: 28px;
        }

        .title-block p {
            margin: 0;
            color: var(--app-muted);
        }

        .toolbar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 12px;
            margin-bottom: 20px;
        }

        .stat {
            background: var(--app-surface);
            border: 1px solid var(--app-border);
            border-radius: 14px;
            padding: 14px;
        }

        .stat .label {
            font-size: 12px;
            color: var(--app-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 6px;
        }

        .stat .value {
            font-size: 24px;
            font-weight: bold;
        }

        .filters {
            background: var(--app-surface);
            border: 1px solid var(--app-border);
            border-radius: 14px;
            padding: 16px;
            margin-bottom: 24px;
        }

        .filters form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
            align-items: end;
        }

        label {
            display: block;
            font-size: 13px;
            color: var(--app-muted);
            margin-bottom: 6px;
        }

        select,
        button {
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid var(--app-border);
            font-size: 14px;
        }

        button {
            cursor: pointer;
            background: var(--app-primary);
            color: white;
            border: none;
            font-weight: 600;
        }

        .card {
            background: var(--app-surface);
            border: 1px solid var(--app-border);
            border-radius: 18px;
        }

        .empty {
            background: var(--app-surface);
            border: 1px dashed var(--app-border);
            border-radius: 16px;
            padding: 28px;
            text-align: center;
            color: var(--app-muted);
        }

        .muted {
            color: var(--app-muted);
        }
    </style>
</head>
<body>
    <div class="app">
        {% include "partials/app_nav.html" %}

        <div class="content">
            <div class="container">
                {% block content %}{% endblock %}
            </div>
        </div>
    </div>
</body>
</html>
